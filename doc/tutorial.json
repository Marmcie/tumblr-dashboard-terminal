          {
            "content": [
              {
                "type": "text",
                "text": "2. You will be greeted by a bunch of options, which should be filled like this.",
                "subtype": "heading1"
              },
              {
                "type": "text",
                "text": "Application Name: Fill it with anything you want.",
                "subtype": "unordered-list-item"
              },
              {
                "type": "text",
                "text": "Application Website: Any website URL.",
                "subtype": "unordered-list-item"
              },
              {
                "type": "text",
                "text": "Application Description: Fill it with anything you want",
                "subtype": "unordered-list-item"
              },
              {
                "type": "text",
                "text": "Administrative contact email: Your tumblr account email address.",
                "subtype": "unordered-list-item"
              },
              {
                "type": "text",
                "text": "Default callback URL: Set it to 'http://localhost:6969'. (Port number can be anything, just make it consistent between other option) ",
                "subtype": "unordered-list-item"
              },
              {
                "type": "text",
                "text": "OAuth2 redirect URLs: Same as Default callback URL",
                "subtype": "unordered-list-item"
              },
              {
                "type": "text",
                "text": "Once all filled up, press Save changes to complete the first step!"
              }
