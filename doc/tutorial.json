            "content": [
              {
                "type": "text",
                "text": "1. Once you are done registering your application, you will be provided with the followings",
                "subtype": "heading1"
              },
              {
                "type": "text",
                "text": "OAuth Consumer Key",
                "subtype": "unordered-list-item"
              },
              {
                "type": "text",
                "text": "Secret key",
                "subtype": "unordered-list-item"
              },
              {
                "type": "text",
                "text": "Take a note on both keys since we'll need them soon."
              }
            ],
            "layout": [],
            "post": {
              "id": "111111111111111111"
            },
            "blog": {
              "name": "tutorial-fairy",
              "title": "Tutorial fairy",
              "description": "Hi! I teach people how to set up this program!",
              "url": "tutorial land",
              "uuid": "t:",
              "updated": 1772222222,
